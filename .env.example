# 巡检宝环境变量配置示例
# 复制此文件为 .env 并根据实际情况修改

# ============================================
# 数据库配置
# ============================================
MYSQL_ROOT_PASSWORD=your_root_password_here
MYSQL_DATABASE=xunjianbao
MYSQL_USER=xunjianbao
MYSQL_PASSWORD=your_mysql_password_here

# ============================================
# Redis 配置
# ============================================
REDIS_PASSWORD=

# ============================================
# JWT 配置（生产环境必须修改！）
# ============================================
# JWT 密钥至少需要 32 个字符
JWT_SECRET=your_jwt_secret_here_at_least_32_characters
# JWT 过期时间（小时）
JWT_EXPIRY=24

# ============================================
# 微服务配置
# ============================================
OPENCLAW_URL=http://localhost:8096
OPENCLAW_TOKEN=your_openclaw_token_here
AI_SERVICE_URL=http://localhost:8095
YOLO_SERVICE_URL=http://localhost:8097
OPENAI_API_KEY=your_openai_api_key_here

# YOLO 设备配置: cpu, cuda, mps (Mac M系列)
YOLO_DEVICE=cpu

# ============================================
# 告警通知 (SMTP)
# ============================================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASSWORD=your_smtp_password

# ============================================
# Rate Limiting（每IP每分钟）
# ============================================
# 登录端点限流
RATE_LIMIT_LOGIN=10
# 通用API限流
RATE_LIMIT_API=120

# ============================================
# 本地开发数据库 URL（可选）
# ============================================
# 如果不设置，后端将使用 SQLite 作为开发数据库
DATABASE_URL=xunjianbao:your_mysql_password_here@tcp(localhost:3306)/xunjianbao?charset=utf8mb4&parseTime=True&loc=Local
