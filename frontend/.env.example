# 巡检宝前端环境配置示例
# 复制此文件为 .env.local 并填写实际值

# API 基础地址
VITE_API_BASE_URL=http://localhost:8094

# AI 服务地址
VITE_AI_SERVICE_URL=http://localhost:8095

# OpenClaw 地址
VITE_OPENCLAW_URL=http://localhost:8096

# WebSocket 地址
VITE_WS_URL=ws://localhost:8094

# 是否启用调试模式
VITE_DEBUG=true

# 应用名称
VITE_APP_NAME=巡检宝

# 应用版本
VITE_APP_VERSION=1.0.0

# 环境
VITE_ENV=development

# 是否启用分析
VITE_ENABLE_ANALYTICS=false

# Sentry DSN (错误追踪)
# VITE_SENTRY_DSN=https://xxxxx@sentry.io/xxxxx
