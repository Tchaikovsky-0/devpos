{
  "name": "xunjianbao-tests",
  "version": "1.0.0",
  "description": "Xunjianbao Testing Configuration",
  "scripts": {
    "test": "Run all tests",
    "test:unit": "Run unit tests only",
    "test:integration": "Run integration tests only",
    "test:e2e": "Run E2E tests only",
    "test:coverage": "Generate coverage reports",
    "test:watch": "Watch mode for development"
  },
  "testSettings": {
    "backend": {
      "unit": {
        "packages": [
          "./internal/service/...",
          "./internal/handler/...",
          "./pkg/..."
        ],
        "timeout": "5m",
        "parallel": true,
        "raceDetector": true
      },
      "integration": {
        "packages": [
          "./tests/..."
        ],
        "timeout": "10m",
        "requiresDb": true,
        "requiresRedis": true
      },
      "coverage": {
        "minimum": 60,
        "target": 80,
        "reports": ["html", "text", "json"]
      }
    },
    "frontend": {
      "unit": {
        "files": [
          "tests/unit/**/*.test.{ts,tsx}"
        ],
        "coverage": true,
        "watch": false
      },
      "integration": {
        "files": [
          "tests/integration/**/*.test.{ts,tsx}"
        ],
        "requiresServer": false
      },
      "e2e": {
        "browsers": ["chromium", "firefox", "webkit"],
        "parallel": true,
        "retries": 2
      },
      "coverage": {
        "minimum": 70,
        "target": 85,
        "reports": ["html", "json", "text", "lcov"]
      }
    }
  },
  "reporting": {
    "formats": ["html", "json", "junit"],
    "output": {
      "unit": "test-results/unit",
      "integration": "test-results/integration",
      "e2e": "test-results/e2e",
      "coverage": "coverage"
    },
    "notifications": {
      "slack": false,
      "email": false
    }
  }
}
