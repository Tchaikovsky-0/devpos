    },
    "with_parallel": {
      "name": "并行优化",
      "description": "仅启用并行",
      "expected_time": "0.3x",
      "improvement": "70%"
    },
    "max_power": {
      "name": "最大功率",
      "description": "所有优化",
      "expected_time": "0.2x",
      "improvement": "500%+"
    }
  },
  "auto_fix_templates": {
    "parallelize": {
      "before": "for item in items:\n    result = await process(item)",
      "after": "results = await asyncio.gather(*[process(item) for item in items])"
    },
    "cache": {
