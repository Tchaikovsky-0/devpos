        "focus": "AI开发 - YOLO检测、OpenClaw Agent、智能分析"
      },
      "platform-squad": {
        "lead": "devops-eng",
        "members": [],
        "focus": "平台运维 - CI/CD、监控、部署、环境"
      },
      "quality-squad": {
        "lead": "qa-lead",
        "members": [],
        "focus": "质量保障 - 测试、质量把控、发布评估"
      }
    }
  },

  "collaboration": {
    "handoffProtocols": {
      "skill-dispatcher-to-lead": {
        "trigger": "复杂任务需要Lead决策",
        "artifacts": ["任务描述", "上下文", "约束条件"],
        "receiver": "project-lead"
      },
      "lead-to-dev": {
        "trigger": "任务已拆解可执行",
        "artifacts": ["API需求文档", "设计文档", "验收标准"],
        "receiver": "相关Dev Agent"
      },
      "dev-to-lead": {
        "trigger": "任务完成需要审查",
        "artifacts": ["代码变更", "测试结果", "自检报告"],
        "receiver": "相关Lead"
      },
      "dev-to-qa": {
        "trigger": "功能开发完成",
        "artifacts": ["功能说明", "测试建议", "自测报告"],
        "receiver": "qa-lead"
      },
      "qa-to-dev": {
        "trigger": "发现Bug需要修复",
        "artifacts": ["Bug报告", "复现步骤", "影响范围"],
        "receiver": "相关Dev"
      }
    },
    "reviewProcess": {
      "codeReview": {
        "frontend": "frontend-lead",
        "backend": "backend-lead",
        "ai": "ai-lead",
        "devops": "devops-eng",
        "final": "project-lead"
      },
      "architectureReview": {
        "reviewers": ["project-lead", "相关领域lead"],
        "required": true,
        "triggers": ["新增模块", "架构变更", "重大重构"]
      },
      "qualityGate": {
        "reviewers": ["qa-lead"],
        "required": true,
        "triggers": ["版本发布", "里程碑完成"]
      }
    }
  },

  "automation": {
    "autoAssign": {
      "enabled": true,
      "rules": [
        {
          "pattern": "前端|React|组件|页面|UI|样式|Tailwind",
          "assignTo": "frontend-dev",
          "notify": "frontend-lead",
          "priority": 1
        },
        {
          "pattern": "架构|设计|组件设计|性能优化|前端Lead",
          "assignTo": "frontend-lead",
          "notify": null,
          "priority": 1
        },
        {
          "pattern": "后端|API|接口|Go|Gin|数据库|Service",
          "assignTo": "backend-dev",
          "notify": "backend-lead",
          "priority": 2
        },
        {
          "pattern": "架构设计|API设计|数据库设计|后端Lead",
          "assignTo": "backend-lead",
          "notify": null,
          "priority": 2
        },
        {
          "pattern": "AI|YOLO|检测|模型|OpenClaw|Agent",
          "assignTo": "ai-lead",
          "notify": null,
          "priority": 3
        },
        {
          "pattern": "部署|CI/CD|Docker|K8s|环境|监控",
          "assignTo": "devops-eng",
          "notify": null,
          "priority": 4
        },
        {
          "pattern": "测试|质量|Bug|QA|测试用例",
          "assignTo": "qa-lead",
          "notify": null,
          "priority": 5
        },
        {
          "pattern": "项目|规划|全局|架构|决策|跨模块",
          "assignTo": "project-lead",
          "notify": null,
          "priority": 0
        }
      ]
    }
  },

  "agentInteraction": {
    "workflowPatterns": {
      "simpleTask": {
        "description": "单一模块任务",
        "flow": ["skill-dispatcher", "dev"],
        "example": "开发一个登录表单"
      },
      "complexTask": {
        "description": "复杂多模块任务",
        "flow": ["skill-dispatcher", "project-lead", "lead", "dev", "lead-review", "qa"],
        "example": "实现视频流管理模块"
      },
      "bugFix": {
        "description": "Bug修复",
        "flow": ["qa-lead", "dev", "lead-review", "qa-verify"],
        "example": "修复视频播放卡顿问题"
      },
      "architectureTask": {
        "description": "架构设计任务",
        "flow": ["project-lead", "lead-design", "project-approve", "dev-implement", "lead-review"],
        "example": "设计新的微服务架构"
      }
    },
    "escalationRules": {
      "P0": {
        "timeout": "立即",
        "path": ["dev", "lead", "project-lead"],
        "notify": "all"
      },
      "P1": {
        "timeout": "15分钟",
        "path": ["dev", "lead", "project-lead"],
        "notify": ["project-lead"]
      },
      "P2": {
        "timeout": "1小时",
        "path": ["dev", "lead"],
        "notify": []
      },
      "P3": {
        "timeout": "4小时",
        "path": ["dev"],
        "notify": []
      }
    }
  },

  "qualityGates": {
    "beforeCommit": {
      "checks": [
        "代码格式化",
        "Linter检查",
        "单元测试通过",
        "类型检查通过"
      ]
    },
    "beforeReview": {
      "checks": [
        "自测通过",
        "测试覆盖达标",
        "无硬编码敏感信息"
      ]
    },
    "beforeMerge": {
      "checks": [
        "代码审查通过",
        "CI流水线通过",
        "无安全漏洞"
      ]
    },
    "beforeRelease": {
      "checks": [
        "QA验收通过",
        "性能测试通过",
        "安全扫描通过",
        "文档完整"
      ]
    }
  }
}
