      "domain": ["task-analysis", "skill-matching", "routing"],
      "reports_to": null,
      "manages": null,
      "invocation": {
        "commands": ["/dispatch", "/skill-dispatch", "/route"],
        "atMention": "@skill-dispatcher",
        "autoTrigger": ["所有开发任务", "任务分析", "技能匹配"]
      },
      "capabilities": {
        "canAssign": true,
        "canReview": false,
        "canApprove": false,
        "canCreatePlan": false
      }
    },

