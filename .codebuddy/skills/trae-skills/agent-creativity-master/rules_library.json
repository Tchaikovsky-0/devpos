        {
          "name": "极端假设",
          "description": "在荒谬假设下寻找灵感",
          "example": "如果是无限资源/零成本会怎样"
        },
        {
          "name": "随机刺激",
          "description": "用随机词激发创意",
          "example": "随机词+问题=意外关联"
        },
        {
          "name": "类比思维",
