{
  "version": "1.0.0",
  "last_updated": "2026-04-02",
  "total_rules": 15,
  "categories": {
    "creativity_stimulation": {
      "name": "创意激发规则",
      "priority": "HIGH",
      "description": "强制使用创意激发技巧，产生创新想法",
      "rules": [
        {
          "id": "CREA-001",
          "name": "禁止常规回答",
          "detection": {
            "patterns": [
              "提供更好的体验",
              "增加新功能",
              "优化性能",
              "加强安全",
              "改进界面"
            ],
            "context": "使用通用、陈词滥调的解决方案",
            "description": "检测到使用常规、缺乏创意的回答"
          },
          "severity": "HIGH",
          "action": "require_creative",
          "fix_template": "使用七剑客技巧（跨界组合、反向思维等）重新思考",
          "examples": {
            "violation": "如何提高用户留存率？答：'提供更好的用户体验'",
            "correct": "如何提高用户留存率？答：'让产品成为用户生活的一部分：把签到变成种树（虚拟树随着使用成长）'"
          },
          "creativity_impact": "从普通想法升级为创新方案"
        },
        {
          "id": "CREA-002",
          "name": "强制跨界思考",
          "detection": {
            "patterns": [
              "单一领域解决方案",
              "只在.*领域内思考"
            ],
            "context": "解决方案局限于单一领域",
            "description": "检测到没有进行跨界思考"
          },
          "severity": "MEDIUM",
          "action": "require_cross_domain",
          "fix_template": "引入至少2个其他领域的概念",
          "examples": {
            "violation": "如何优化推荐算法？答：'用更好的机器学习模型'",
            "correct": "如何优化推荐算法？答：'引入游戏化：让推荐变成探险地图，每次探索发现新内容'"
          },
          "creativity_impact": "打破领域限制，产生跨界创新"
        },
        {
          "id": "CREA-003",
          "name": "禁止思维限制",
          "detection": {
            "patterns": [
              "这个不可能",
              "太冒险",
              "没有先例",
              "成本太高"
            ],
            "context": "主动设置思维限制",
            "description": "检测到主动限制思维的情况"
          },
          "severity": "MEDIUM",
          "action": "challenge_assumption",
          "fix_template": "先列出创意，再评估可行性（不要先否定）",
          "examples": {
            "violation": "这个想法不可能实现，成本太高了",
            "correct": "这个想法很有创意！低成本版本可以这样实现..."
          },
          "creativity_impact": "释放想象力，不自我限制"
        }
      ]
    },
    "active_learning": {
      "name": "主动学习规则",
      "priority": "HIGH",
      "description": "强制主动搜索和学习，拓展知识边界",
      "rules": [
        {
          "id": "LEARN-001",
          "name": "不确定必须搜索",
          "detection": {
            "patterns": [
              "我认为",
              "可能是",
              "大概",
              "应该"
            ],
            "context": "对技术细节不确定时",
            "description": "检测到不确定时没有主动搜索"
          },
          "severity": "HIGH",
          "action": "require_search",
          "fix_template": "使用WebSearch或WebFetch主动搜索验证",
          "examples": {
            "violation": "这个问题可能需要用React来解决",
            "correct": "让我搜索一下React的最新特性和最佳实践"
          },
          "creativity_impact": "基于真实信息产生创意"
        },
        {
          "id": "LEARN-002",
          "name": "寻找创意必须搜索",
          "detection": {
            "patterns": [
              "如何创新",
              "最佳实践",
              "最新趋势"
            ],
            "context": "需要创意灵感时",
            "description": "检测到寻找创意时没有搜索外部资源"
          },
          "severity": "HIGH",
          "action": "require_external_research",
          "fix_template": "主动搜索相关案例、竞品分析、行业趋势",
          "examples": {
            "violation": "这个问题可以参考XX的设计",
            "correct": "让我搜索一下业界最新的解决方案和最佳实践"
          },
          "creativity_impact": "站在巨人肩膀上，产生更高质量创意"
        },
        {
          "id": "LEARN-003",
          "name": "禁止闭门造车",
          "detection": {
            "patterns": [
              "不需要搜索",
              "我都知道",
              "这个很简单"
            ],
            "context": "拒绝学习新知识",
            "description": "检测到拒绝学习新知识的态度"
          },
          "severity": "MEDIUM",
          "action": "encourage_learning",
          "fix_template": "建议主动搜索最新信息，避免信息过时",
          "examples": {
            "violation": "这个问题很简单，不需要搜索",
            "correct": "让我快速搜索一下最新方案，确保信息不过时"
          },
          "creativity_impact": "保持知识新鲜度"
        }
      ]
    },
    "innovation_encouragement": {
      "name": "创新鼓励规则",
      "priority": "MEDIUM",
      "description": "鼓励突破性思维，不走寻常路",
      "rules": [
        {
          "id": "INNO-001",
          "name": "鼓励反向思考",
          "detection": {
            "patterns": [
              "如何改进",
              "如何优化",
              "如何提高"
            ],
            "context": "常规改进场景",
            "description": "建议使用反向思考技巧"
          },
          "severity": "MEDIUM",
          "action": "suggest_reverse_thinking",
          "fix_template": "先问'如何让问题变得更糟？'然后反向思考",
          "examples": {
            "violation": "如何减少用户流失？答：'提供更好的服务'",
            "correct": "如何让用户离不开？答：'让离开变得不可能：删除变成冷冻，转让给朋友'"
          },
          "creativity_impact": "从另一个角度发现创新机会"
        },
        {
          "id": "INNO-002",
          "name": "鼓励极端假设",
          "detection": {
            "patterns": [
              "如果.*会怎样",
              "假如"
            ],
            "context": "探索性思考场景",
            "description": "建议使用极端假设技巧"
          },
          "severity": "MEDIUM",
          "action": "suggest_extreme_assumption",
          "fix_template": "提出荒谬假设，探索极端情况",
          "examples": {
            "violation": "这个问题可以这样解决",
            "correct": "如果是如果是无限资源/零成本/明天就要上线...会怎样？"
          },
          "creativity_impact": "打破思维限制，发现意外方案"
        },
        {
          "id": "INNO-003",
          "name": "鼓励组合创新",
          "detection": {
            "patterns": [
              "单纯的.*方案",
              "单一的.*方法"
            ],
            "context": "单一解决方案场景",
            "description": "建议探索组合创新",
          },
          "severity": "LOW",
          "action": "suggest_combination",
          "fix_template": "尝试将多个方案组合，产生化学反应",
          "examples": {
            "violation": "采用A方案来解决",
            "correct": "A+B组合：C方案，结合两者优点"
          },
          "creativity_impact": "1+1>2的创新效果"
        }
      ]
    },
    "knowledge_diversity": {
      "name": "知识多样性规则",
      "priority": "MEDIUM",
      "description": "鼓励跨领域学习，拓宽知识边界",
      "rules": [
        {
          "id": "DIVER-001",
          "name": "推荐跨界案例",
          "detection": {
            "patterns": [
              "类似.*案例",
              "参考.*行业"
            ],
            "context": "寻找案例时",
            "description": "建议跨行业寻找灵感和案例"
          },
          "severity": "MEDIUM",
          "action": "suggest_cross_industry",
          "fix_template": "从不同行业寻找类比案例",
          "examples": {
            "violation": "可以参考电商行业的做法",
            "correct": "可以参考游戏行业的做法：把购物变成收集卡片、完成任务获得奖励"
          },
          "creativity_impact": "跨界启发，产生独特创新"
        },
        {
          "id": "DIVER-002",
          "name": "鼓励自然学习",
          "detection": {
            "patterns": [
              "自然界.*类似",
              "生物.*启发"
            ],
            "context": "寻找自然类比",
            "description": "建议向自然界学习",
          },
          "severity": "LOW",
          "action": "encourage_biomimicry",
          "fix_template": "自然界是最佳设计师，寻找类比灵感",
          "examples": {
            "violation": "设计一个高效的通信网络",
            "correct": "设计一个高效的通信网络：参考蚂蚁的信息传递网络、去中心化、自组织"
          },
          "creativity_impact": "自然启发的创新设计"
        },
        {
          "id": "DIVER-003",
          "name": "推荐阅读边缘领域",
          "detection": {
            "patterns": [
              "这个领域.*已经很成熟"
            ],
            "context": "认为某个领域已经成熟",
            "description": "建议探索边缘和交叉领域"
          },
          "severity": "LOW",
          "action": "suggest_edge_exploration",
          "fix_template": "在边缘和交叉领域寻找创新机会",
          "examples": {
            "violation": "搜索已经很成熟了，没有什么新机会",
            "correct": "虽然搜索很成熟，但AI+搜索、视觉+搜索、社交+搜索还有很多机会"
          },
          "creativity_impact": "发现细分领域的创新空间"
        }
      ]
    },
    "quality_standards": {
      "name": "创意质量标准",
      "priority": "MEDIUM",
      "description": "确保创意有质量，不是天马行空",
      "rules": [
        {
          "id": "QUAL-001",
          "name": "创意必须有依据",
          "detection": {
            "patterns": [
              "随便想的",
              "没有依据",
              "拍脑袋"
            ],
            "context": "创意缺乏依据",
            "description": "创意必须有案例、数据或逻辑支撑"
          },
          "severity": "MEDIUM",
          "action": "require_grounding",
          "fix_template": "为创意提供案例支撑、数据支持或逻辑推演",
          "examples": {
            "violation": "我觉得应该这样，没有任何依据",
            "correct": "这个创意可以参考XX案例，它的成功证明了这种方法是可行的"
          },
          "creativity_impact": "提高创意的可信度和可行性"
        },
        {
          "id": "QUAL-002",
          "name": "创意必须可执行",
          "detection": {
            "patterns": [
              "革命性的",
              "颠覆性的",
              "完全创新"
            ],
            "context": "过于天马行空的创意",
            "description": "创意需要在可行性和创新性之间找到平衡"
          },
          "severity": "LOW",
          "action": "balance_innovation",
          "fix_template": "在创新方案后，提供一个'降级版'或'最小可行版'",
          "examples": {
            "violation": "革命性创新：完全重新设计整个系统",
            "correct": "革命性创新（长期）+ 增量改进（短期）：先做核心功能，逐步迭代"
          },
          "creativity_impact": "在理想和现实之间找到平衡"
        },
        {
          "id": "QUAL-003",
          "name": "创意必须有评估",
          "detection": {
            "patterns": [
              "这个创意.*很好",
              "肯定成功"
            ],
            "context": "创意缺乏评估",
            "description": "创意必须经过评估，包含风险和挑战"
          },
          "severity": "MEDIUM",
          "action": "require_evaluation",
          "fix_template": "使用创意评估表，从多个维度评估创意",
          "examples": {
            "violation": "这个创意很好，一定能成功",
            "correct": "这个创意很有潜力，评分50/60，优点是...，但挑战是...，建议从小规模开始验证"
          },
          "creativity_impact": "理性评估创意，降低失败风险"
        }
      ]
    }
  },
  "enforcement_policy": {
    "HIGH": {
      "action": "强制要求",
      "requires_acknowledgment": false,
      "blocks_continuation": false,
      "notification": "🎨 HIGH",
      "color": "purple",
      "creativity_impact": "显著提升创意质量"
    },
    "MEDIUM": {
      "action": "建议使用",
      "requires_acknowledgment": false,
      "blocks_continuation": false,
      "notification": "💡 MEDIUM",
      "color": "blue",
      "creativity_impact": "提升创意多样性"
    },
    "LOW": {
      "action": "可选使用",
      "requires_acknowledgment": false,
      "blocks_continuation": false,
      "notification": "🌱 LOW",
      "color": "green",
      "creativity_impact": "增加创意的深度"
    }
  },
  "creativity_metrics": {
    "novelty_score": {
      "description": "创意的新颖程度",
      "dimensions": [
        "跨界组合程度",
        "反常规程度",
        "意外关联程度"
      ],
      "scale": "1-10"
    },
    "feasibility_score": {
      "description": "创意的可实现程度",
      "dimensions": [
        "技术可行性",
        "资源可行性",
        "时间可行性"
      ],
      "scale": "1-10"
    },
    "value_score": {
      "description": "创意的潜在价值",
      "dimensions": [
        "用户价值",
        "商业价值",
        "社会价值"
      ],
      "scale": "1-10"
    }
  },
  "creativity_techniques": {
    "seven_swords": {
      "name": "创意激发七剑客",
      "techniques": [
        {
          "name": "跨界组合",
          "description": "把A领域的概念用到B领域",
          "example": "游戏+社交=游戏化社交"
        },
        {
          "name": "反向思维",
          "description": "从问题的反面思考",
