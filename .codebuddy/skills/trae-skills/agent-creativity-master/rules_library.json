        },
        {
          "name": "水平思考",
          "steps": ["挑战假设", "随机输入", "分割重组"],
          "focus": "跳出逻辑"
        }
      ]
    }
  },
  "search_guidelines": {
    "when_to_search": [
      "不确定技术细节时",
      "寻找创意灵感时",
      "验证想法是否有先例时",
      "需要系统性学习某个领域时",
      "想了解最新趋势时"
    ],
    "search_strategies": {
      "technical": {
        "channels": ["Stack Overflow", "GitHub", "技术博客"],
        "keywords_tips": "技术栈名称 + 最佳实践/最新特性"
      },
      "creative": {
        "channels": ["Product Hunt", "Behance", "Dribbble", "设计灵感网站"],
        "keywords_tips": "领域 + 创新设计/有趣案例"
      },
      "trends": {
        "channels": ["Twitter", "科技博客", "行业报告"],
        "keywords_tips": "领域 + 2024趋势/最新动态"
      },
      "academic": {
        "channels": ["Google Scholar", "arXiv", "CNKI"],
        "keywords_tips": "核心概念 + research/latest"
      }
    },
    "information_integration": {
      "step1": "收集（宽泛）- 先堆量，不做筛选",
      "step2": "筛选（严格）- 评估可信度、相关性、时效性",
      "step3": "整理（结构化）- 按主题、时间线、观点分类",
      "step4": "提炼（观点）- 找出共同点、分歧点，形成自己的观点"
    }
  },
  "evaluation_templates": {
    "creative_score_matrix": {
      "dimensions": [
        {"name": "问题匹配度", "weight": 1, "max": 10},
        {"name": "创新程度", "weight": 1, "max": 10},
        {"name": "可行性", "weight": 1, "max": 10},
        {"name": "商业价值", "weight": 1, "max": 10},
        {"name": "扩展性", "weight": 1, "max": 10},
        {"name": "用户接受度", "weight": 1, "max": 10}
      ],
      "total_max": 60,
      "thresholds": {
        "super": {"min": 50, "label": "超级创意，立即执行"},
        "excellent": {"min": 40, "label": "优秀创意，值得尝试"},
        "average": {"min": 30, "label": "一般创意，需要改进"},
        "needs_review": {"min": 0, "label": "需要重新思考"}
      }
    },
    "pros_cons_analysis": {
      "sections": [
        {"name": "优点", "items": []},
        {"name": "缺点", "items": []},
        {"name": "改进机会", "items": []},
        {"name": "实施路径", "items": []},
        {"name": "风险与应对", "items": []}
      ]
    }
  },
  "creativity_exercises": {
    "five_minute": {
      "name": "5分钟创意激发",
      "duration": "5分钟",
      "goal": "产生10个创意",
      "steps": [
        {"time": "30秒", "action": "明确问题，写下要解决的问题"},
        {"time": "2分钟", "action": "快速发散，写下所有想法，不审查"},
        {"time": "1分钟", "action": "强制组合，把任意2个想法组合"},
        {"time": "1分钟", "action": "疯狂延伸，把组合推向极端"},
        {"time": "30秒", "action": "筛选评估，选出最有潜力的3个"}
      ]
    },
    "thirty_minute": {
      "name": "30分钟深度创意",
      "duration": "30分钟",
      "goal": "产出一个可执行的创意方案",
      "steps": [
        {"time": "5分钟", "action": "问题定义：深入理解问题，列出约束，定义成功标准"},
        {"time": "5分钟", "action": "广泛调研：搜索相关案例，了解竞品，收集灵感"},
