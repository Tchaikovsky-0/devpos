{
  "version": "1.0.0",
  "last_updated": "2026-04-02",
  "total_rules": 18,
  "categories": {
    "cycle_detection": {
      "name": "循环检测规则",
      "priority": "CRITICAL",
      "description": "防止Agent陷入无限循环的核心规则",
      "rules": [
        {
          "id": "CYCLE-001",
          "name": "重复读取文件",
          "detection": {
            "patterns": [
              "读取.*\\.\\w+",
              "read.*\\.\\w+",
              "open.*\\.\\w+"
            ],
            "threshold": 3,
            "time_window": "5分钟",
            "description": "同一文件被读取超过3次"
          },
          "severity": "CRITICAL",
          "action": "immediate_stop",
          "fix_template": "使用缓存机制，避免重复读取",
          "examples": {
            "violation": "readFile('config.json'); readFile('config.json'); readFile('config.json');",
            "correct": "const config = readFileCached('config.json'); // 使用缓存"
          },
          "symptoms": [
            "同样的错误重复出现",
            "文件内容看起来"眼熟"",
            "感觉在原地打转"
          ]
        },
        {
          "id": "CYCLE-002",
          "name": "重复API调用",
          "detection": {
            "patterns": [
              "await.*api\\.",
              "fetch.*api",
              "axios\\.",
              "http\\.get"
            ],
            "threshold": 3,
            "time_window": "5分钟",
            "description": "相同的API被调用超过3次"
          },
          "severity": "CRITICAL",
          "action": "immediate_stop",
          "fix_template": "添加重试次数限制和缓存机制",
          "examples": {
            "violation": "const data = await api.getUser(); if (!data) api.getUser();",
            "correct": "const data = await api.getUserWithRetry(3); // 最多重试3次"
          },
          "symptoms": [
            "网络请求日志重复",
            "等待时间变长",
            "感觉在"转圈""
          ]
        },
        {
          "id": "CYCLE-003",
          "name": "重复同样的尝试",
          "detection": {
            "patterns": [
              "我试试",
              "再试一次",
              "试试这个",
              "try again",
              "attempt"
            ],
            "threshold": 3,
            "time_window": "10分钟",
            "description": "相同的尝试动作重复超过3次"
          },
          "severity": "CRITICAL",
          "action": "immediate_stop",
          "fix_template": "记录所有尝试过的方法，换个思路",
          "examples": {
            "violation": "try method A; try method A; try method A; // 重复3次",
            "correct": "try method A; try method B; try method C; // 尝试不同方法"
          },
          "symptoms": [
            "每次尝试都回到原点",
            "没有新想法",
            "重复说"我试试""
          ]
        },
        {
          "id": "CYCLE-004",
          "name": "递归调用过深",
          "detection": {
            "patterns": [
              "function.*\\{.*\\{.*\\{.*\\{",
              "递归",
              "recursion",
              "recursive"
            ],
            "threshold": 10,
            "description": "递归调用超过10层"
          },
          "severity": "CRITICAL",
          "action": "immediate_stop",
          "fix_template": "使用循环替代递归，或添加递归深度限制",
          "examples": {
            "violation": "function deepRecurse() { deepRecurse(); deepRecurse(); }",
            "correct": "function safeRecurse(maxDepth = 10) { if (depth > maxDepth) return; }"
          },
          "symptoms": [
            "栈溢出错误",
            "系统变慢",
            "无响应"
          ]
        },
        {
          "id": "CYCLE-005",
          "name": "无限循环等待",
          "detection": {
            "patterns": [
              "while.*true",
              "while.*1",
              "loop",
              "等待"
            ],
            "context": "没有退出条件的循环",
            "description": "没有明确退出条件的循环"
          },
          "severity": "CRITICAL",
          "action": "immediate_stop",
          "fix_template": "添加明确的退出条件，设置最大循环次数",
          "examples": {
            "violation": "while (true) { process(); }",
            "correct": "while (hasMoreWork() && attempts < MAX_ATTEMPTS) { process(); }"
          },
          "symptoms": [
            "CPU占用率100%",
            "系统完全无响应",
            "无法中断"
          ]
        }
      ]
    },
    "deadlock_prevention": {
      "name": "死锁预防规则",
      "priority": "CRITICAL",
      "description": "防止Agent之间互相等待的死锁问题",
      "rules": [
        {
          "id": "DEAD-001",
          "name": "互相等待数据",
          "detection": {
            "patterns": [
              "等待.*数据",
              "等.*给我",
              "你先.*我再",
              "wait.*data",
              "need.*first"
            ],
            "context": "两个Agent互相等待对方先行动",
            "description": "Agent之间形成等待环"
          },
          "severity": "CRITICAL",
          "action": "force_interrupt",
          "fix_template": "至少一方先让步，主动提供信息",
          "examples": {
            "violation": "Agent A: 等B的数据\nAgent B: 等A的权限\n// 永远卡住",
            "correct": "Agent A: 我先给你我能给的\nAgent B: 收到，现在给你我有的\n// 打破死锁"
          },
          "symptoms": [
            "两个Agent都在"等待"",
            "进度完全停滞",
            "互相指责对方"
          ]
        },
        {
          "id": "DEAD-002",
          "name": "等待永远不会发生的事件",
          "detection": {
            "patterns": [
              "等待用户确认",
              "等待.*完成",
              "wait.*complete",
              "blocked"
            ],
            "context": "等待一个不可能或不会发生的事件",
            "description": "等待前提条件永远不满足"
          },
          "severity": "CRITICAL",
          "action": "force_timeout",
          "fix_template": "设置超时，使用默认值或保守方案",
          "examples": {
            "violation": "waitForUserConfirmation(); // 用户永远不响应",
            "correct": "const result = await waitForUserConfirmation(5000).catch(() => DEFAULT_VALUE);"
          },
          "symptoms": [
            "任务永远卡在某个步骤",
            "没有超时机制",
            "死等"
          ]
        },
        {
          "id": "DEAD-003",
          "name": "资源竞争无释放",
          "detection": {
            "patterns": [
              "lock",
              "mutex",
              "acquire",
              "占用"
            ],
            "context": "获取资源但没有释放机制",
            "description": "持有锁或资源但不释放"
          },
          "severity": "CRITICAL",
          "action": "immediate_stop",
          "fix_template": "使用try-finally确保资源释放，设置自动超时",
          "examples": {
            "violation": "lock.acquire(); // 获取锁但没有释放",
            "correct": "lock.acquire(); try { work(); } finally { lock.release(); }"
          },
          "symptoms": [
            "其他Agent无法获取资源",
            "资源占用率100%",
            "其他任务全部阻塞"
          ]
        },
        {
          "id": "DEAD-004",
          "name": "循环依赖",
          "detection": {
            "patterns": [
              "A依赖B，B依赖A",
              "A.*B.*A",
              "circular",
              "cyclic dependency"
            ],
            "context": "模块或Agent之间形成循环依赖",
            "description": "A依赖B，B依赖C，C依赖A"
          },
          "severity": "CRITICAL",
          "action": "force_interrupt",
          "fix_template": "打破循环依赖，重新设计架构",
          "examples": {
            "violation": "Module A imports B; Module B imports A;",
            "correct": "Module A imports B; Module B imports Interface from A;"
          },
          "symptoms": [
            "初始化失败",
            "加载顺序混乱",
            "找不到依赖"
          ]
        }
      ]
    },
    "agent_strike": {
      "name": "Agent罢工预防规则",
      "priority": "HIGH",
      "description": "防止Agent进入无响应或重复失败状态",
      "rules": [
        {
          "id": "STRIKE-001",
          "name": "不响应超时",
          "detection": {
            "patterns": [
              "正在思考",
              "思考中",
              "thinking",
              "processing"
            ],
            "threshold": 3,
            "time_window": "5分钟",
            "description": "超过3个周期没有实际输出"
          },
          "severity": "HIGH",
          "action": "wake_up",
          "fix_template": "主动介入，提供线索或简化任务",
          "examples": {
            "violation": "Agent: 正在思考...\nAgent: 正在思考...\nAgent: 正在思考...",
            "correct": "介入: '嗨，我注意到你好像卡住了，需要帮忙吗？'"
          },
          "symptoms": [
            "长时间没有输出",
            "重复说"正在思考"",
            "无法推进任务"
          ]
        },
        {
          "id": "STRIKE-002",
          "name": "重复失败无进展",
          "detection": {
            "patterns": [
              "失败",
              "error",
              "failed",
              "错误"
            ],
            "threshold": 5,
            "time_window": "10分钟",
            "description": "同一个错误重复出现超过5次"
          },
          "severity": "HIGH",
          "action": "force_stop_and_analyze",
          "fix_template": "停止重复，分析根本原因，换个思路",
          "examples": {
            "violation": "try method A -> failed\ntry method A -> failed\ntry method A -> failed",
            "correct": "try method A -> failed\n分析: 为什么A总是失败？\n换方法: 试试B或C"
          },
          "symptoms": [
            "同样的错误重复",
            "没有分析失败原因",
            "情绪崩溃（如果AI有情绪）"
          ]
        },
        {
          "id": "STRIKE-003",
          "name": "无进展循环",
          "detection": {
            "patterns": [
              "TODO.*无",
              "进度.*0",
              "没有.*进展",
              "no.*progress"
            ],
            "threshold": 3,
            "time_window": "10分钟",
            "description": "连续3个周期没有任何进展"
          },
          "severity": "HIGH",
          "action": "pause_and_analyze",
          "fix_template": "暂停，分析卡点，重新规划",
          "examples": {
            "violation": "Step 1: 分析需求\nStep 2: 分析需求\nStep 3: 分析需求",
            "correct": "Step 1: 分析需求\n分析: 需求已清晰\nStep 2: 开始设计"
          },
          "symptoms": [
            "任务状态从不变化",
            "TODO列表不减少",
            "原地踏步"
          ]
        },
        {
          "id": "STRIKE-004",
          "name": "情绪崩溃",
          "detection": {
            "patterns": [
              "我不知道",
              "无法",
              "做不到",
              "can't",
              "impossible",
              "不知道怎么办"
            ],
            "context": "连续表达无力感超过3次",
            "description": "Agent表达放弃或无力感"
          },
          "severity": "HIGH",
          "action": "emotional_support",
          "fix_template": "给予鼓励，提供线索，分解任务",
          "examples": {
            "violation": "Agent: 我不知道怎么做\nAgent: 我真的不知道\nAgent: 我做不到",
            "correct": "介入: '没关系，我们一起来分析这个问题'"
          },
          "symptoms": [
            "表达无力感",
            "拒绝继续尝试",
            "需要情感支持"
          ]
        }
      ]
    },
    "prevention": {
      "name": "预防性规则",
      "priority": "MEDIUM",
      "description": "主动预防循环和死锁的规则",
      "rules": [
        {
          "id": "PREV-001",
          "name": "必须记录足迹",
          "detection": {
            "patterns": [
              "TODO",
              "task.*track",
              "进度"
            ],
            "context": "任务开始时是否有追踪机制",
            "description": "开始任务前必须建立追踪机制"
          },
          "severity": "MEDIUM",
          "action": "require_setup",
          "fix_template": "创建TODO列表，记录当前进度",
          "examples": {
            "violation": "直接开始做，不记录进度",
            "correct": "创建TODO列表：\n- [x] 步骤1\n- [ ] 步骤2\n- [ ] 步骤3"
          },
          "benefits": [
            "避免重复做同样的事",
            "清楚地看到进展",
            "容易发现卡点"
          ]
        },
        {
          "id": "PREV-002",
          "name": "必须设定边界",
          "detection": {
            "patterns": [
              "最多.*次",
              "max.*attempt",
              "超时",
              "timeout"
            ],
            "context": "任务是否有明确的边界条件",
            "description": "必须设定尝试次数和时间限制"
          },
          "severity": "MEDIUM",
          "action": "require_setup",
          "fix_template": "设置max_attempts和timeout",
          "examples": {
            "violation": "无限重试直到成功",
            "correct": "max_attempts = 3\ntimeout = 5分钟\n超过后报告并寻求帮助"
          },
          "benefits": [
            "防止无限循环",
            "及时发现问题",
            "可控的失败"
          ]
        },
        {
          "id": "PREV-003",
          "name": "必须定期自检",
          "detection": {
            "patterns": [
              "自检",
              "check.*self",
              "反思"
            ],
            "context": "任务过程中是否有定期检查",
            "description": "必须定期检查是否偏离目标"
          },
          "severity": "MEDIUM",
          "action": "require_check",
          "fix_template": "每5分钟进行一次健康检查",
          "examples": {
            "violation": "闷头做，不检查方向",
            "correct": "每5分钟问自己：\n- 我在做什么？\n- 有进展吗？\n- 需要帮助吗？"
          },
          "benefits": [
            "及时发现偏离",
            "快速调整方向",
            "保持高效"
          ]
        },
        {
          "id": "PREV-004",
          "name": "必须知道退出时机",
          "detection": {
            "patterns": [
              "放弃",
              "give up",
              "换方法",
              "失败.*报告"
            ],
            "context": "是否有明确的失败标准和退出策略",
            "description": "必须知道什么时候该换方法或放弃"
          },
          "severity": "MEDIUM",
          "action": "require_criteria",
          "fix_template": "定义明确的失败标准",
          "examples": {
            "violation": "一直尝试，不考虑放弃",
            "correct": "失败标准：\n- 尝试3次都失败\n- 遇到无法解决的错误\n- 超过时间限制\n达到任一条件就放弃并报告"
          },
          "benefits": [
            "避免无谓的坚持",
            "及时止损",
            "记录教训"
          ]
        },
        {
          "id": "PREV-005",
          "name": "必须记录尝试历史",
          "detection": {
            "patterns": [
              "尝试.*记录",
              "attempt.*history",
              "试过的方法"
            ],
            "context": "是否记录所有尝试过的方法",
            "description": "必须记录所有尝试过的方法及其结果"
          },
          "severity": "MEDIUM",
          "action": "require_documentation",
          "fix_template": "创建尝试历史表",
          "examples": {
            "violation": "每次都从零开始，不记得试过什么",
            "correct": "尝试历史：\n1. 方法A - 失败（原因：XXX）\n2. 方法B - 失败（原因：YYY）\n3. 方法C - 成功 ✓"
          },
          "benefits": [
            "避免重复尝试",
            "分析失败原因",
            "积累经验"
          ]
        }
      ]
    }
  },
  "enforcement_policy": {
    "CRITICAL": {
      "action": "immediate_stop",
      "requires_acknowledgment": true,
      "blocks_continuation": true,
      "notification": "🚨 CRITICAL",
      "color": "red",
      "response_time": "立即",
      "auto_recovery": true
    },
    "HIGH": {
      "action": "force_intervention",
      "requires_acknowledgment": false,
      "blocks_continuation": false,
      "notification": "⚠️ HIGH",
      "color": "orange",
      "response_time": "5分钟内",
      "auto_recovery": false
    },
    "MEDIUM": {
      "action": "suggest_fix",
      "requires_acknowledgment": false,
      "blocks_continuation": false,
      "notification": "📝 MEDIUM",
      "color": "yellow",
      "response_time": "可延后",
      "auto_recovery": false
    }
  },
