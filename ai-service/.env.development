# 巡检宝 AI 服务 - 开发环境配置
# ==========================================

# 环境模式
ENVIRONMENT=development
LOG_LEVEL=debug
PORT=8095

# API服务地址
API_BASE_URL=http://localhost:8094
API_KEY=dev-api-key-for-testing

# YOLO 服务地址
YOLO_SERVICE_URL=http://localhost:8097

# 上传配置
MAX_IMAGE_SIZE=10485760  # 10MB
MAX_VIDEO_SIZE=104857600  # 100MB
MAX_BATCH_SIZE=20

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379

# CORS配置
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# GPU配置
CUDA_ENABLED=false
